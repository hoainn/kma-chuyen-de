# Experiment configuration — full DongTing run of SyscallAD (paths are container-internal).
# Consumed by run_experiment.sh (docker --env-file) and rigorous_eval.py.

# --- Data / IO (container paths; host mounts set in run_experiment.sh) ---
DATA_ROOT=/data/dongting
SYSCALL_TBL=/data/dongting/syscall_64.tbl
OUTPUT_DIR=/model
DATA_MAX_SEQ_LEN=50000

# --- Pipeline (pinned — see EXPERIMENT_DESIGN.md §2) ---
USE_SLIDING_WINDOW=1
WINDOW_LEN=15
WINDOW_STRIDE=3
USE_TEMPORAL=0
SENSOR_ALPHABET=1
TOP_K_FREQ=8
TOP_K_DISC=24
TOP_K_BIGRAMS=0
ENABLE_STATS=1
THRESHOLD_STRATEGY=p995
MAX_WINDOWS_PER_SPLIT=2000000
# Evaluate every VAE seed's full ensemble on test → per-seed metrics + mean±SD
# in results.json (ensemble_seed_test_summary). Adds ~2 extra train/val/test
# VAE scorings; default off in the trainer, ON for this experiment.
MULTISEED_TEST_EVAL=1

# --- Reproduction criterion ---
# NOTE: DeSFAM does NOT publish a per-model AUC/AP/F1 table for SyscallAD on DongTing
# (only aggregate headline ~AUC 0.94 / F1 0.92). The old PUB_IF/VAE/ENS=0.646/0.747/
# 0.656 were a MISLABELLED earlier run, not paper numbers — removed. rigorous_eval.py
# now reports a qualitative reproduction criterion (feature parity + ranking + precision
# orientation) and only a qualitative reference to the aggregate headline.
# Max acceptable benign-window FPR for "precision preserved".
SUCCESS_MAX_FPR=0.02
