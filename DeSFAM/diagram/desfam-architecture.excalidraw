    {
      "type": "text",
      "id": "tetragon_text",
      "x": 72, "y": 138,
      "width": 201, "height": 400,
      "text": "Tetragon eBPF Agent\n\ntracing-policy.yaml\n─────────────────\nopenat  read  write\nexecve  clone  wait4\nmmap  mprotect\nsocket  connect  bind\naccept  sendto\ngetdents64  stat\nunshare  init_module\nptrace\n─────────────────\nkprobe hooks on\neach cluster node",
      "originalText": "Tetragon eBPF Agent\n\ntracing-policy.yaml\n─────────────────\nopenat  read  write\nexecve  clone  wait4\nmmap  mprotect\nsocket  connect  bind\naccept  sendto\ngetdents64  stat\nunshare  init_module\nptrace\n─────────────────\nkprobe hooks on\neach cluster node",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "center",
      "verticalAlign": "middle",
      "strokeColor": "#4c1d95",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
